<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="LoginController">
    <children>
        <ImageView fitHeight="400" fitWidth="600">
            <image>
                <Image url="@image/photo_2025-12-14_17-39-28.jpg" />
            </image>
        </ImageView>

        <TextField fx:id="usernameField" layoutX="201.0" layoutY="148.0" promptText="user name">
         <font>
            <Font name="System Bold" size="15.0" />
         </font></TextField>
        <PasswordField fx:id="passwordField" layoutX="201.0" layoutY="220.0" prefHeight="31.0" prefWidth="198.0" promptText="password">
         <font>
            <Font name="System Bold Italic" size="15.0" />
         </font></PasswordField>

        <Button layoutX="443.0" layoutY="339.0" onAction="#loginClicked" prefHeight="25.0" prefWidth="69.0" text="login" />

        <Button layoutX="95.0" layoutY="339.0" onAction="#register_click" prefHeight="25.0" prefWidth="69.0" text="register" />
    </children>

</Pane>
